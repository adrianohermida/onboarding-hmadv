{
  "name": "portal-superendividado",
  "version": "1.0.0",
  "description": "Portal Jurídico do Superendividado — frontend modular para acompanhamento de casos de superendividamento",
  "scripts": {
    "dev": "npx serve . -l 3000",
    "web:dev": "npm --prefix apps/web run dev",
    "build": "echo 'Site estático — sem build step necessário'",
    "web:build": "npm --prefix apps/web run build",
    "web:start": "npm --prefix apps/web run start",
    "web:type-check": "npm --prefix apps/web run type-check",
    "deploy": "git add -A && git commit -m \"deploy: atualizar portal\" && git push origin main",
    "test": "node platform/scripts/run-portal-tests.mjs",
    "git:unify-main": "powershell -ExecutionPolicy Bypass -File ./platform/scripts/unify-main.ps1",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianohermida/onboarding-hmadv.git"
  },
  "author": "Adriano Hermida Maia",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@storybook/html": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@types/node": "^25.9.1",
    "jsdom": "^26.1.0",
    "storybook": "^8.6.14",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "react": "^19.2.6"
  }
}
